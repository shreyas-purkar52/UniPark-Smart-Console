// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  password String
  role     String  // ADMIN, SECURITY, OPERATOR
  stationId String
  createdAt DateTime @default(now())
}

model Slot {
  id       String @id @default(cuid())
  slotId   String @unique
  levelId  Int
  slotNumber Int
  status   String  // AVAILABLE, OCCUPIED, RESERVED
  category String  // FACULTY, STUDENT, VISITOR, VIP
  vehicleId String?
  vehicle  Vehicle? @relation(fields: [vehicleId], references: [vehicleId])
  createdAt DateTime @default(now())
}

model Vehicle {
  id        String @id @default(cuid())
  vehicleId String @unique
  plateNumber String @unique
  ownerName String
  phoneNumber String
  role      String  // STUDENT, FACULTY, VIP, VISITOR
  studentType String?
  photoUrl  String?
  vehicleType String?
  slots     Slot[]
  logs      Log[]
  createdAt DateTime @default(now())
}

model Log {
  id        String @id @default(cuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [vehicleId], onDelete: Cascade)
  slotId    String
  levelId   Int
  entryTime DateTime
  exitTime  DateTime?
  status    String  // Active, Completed
  createdAt DateTime @default(now())
}